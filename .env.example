SCHEDULER_PORT=4010
PORT=4010

MONGODB_URL=mongodb://127.0.0.1:27017/egl

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=false


SCHEDULER_HMAC_KEY_ID=main-backend
SCHEDULER_HMAC_SECRET=replace_with_strong_secret
SCHEDULER_ALLOWED_SKEW_MS=300000

# Admin backend integration (for leaderboard/POTM execution)
ADMIN_BACKEND_BASE_URL=http://127.0.0.1:5003
ADMIN_BACKEND_TIMEOUT_MS=15000

# Optional overrides (defaults to SCHEDULER_HMAC_* above)
ADMIN_BACKEND_HMAC_KEY_ID=
ADMIN_BACKEND_HMAC_SECRET=

# Recurring auto schedules (IST by default)
SCHEDULER_ENABLE_RECURRING=true
SCHEDULER_RECURRING_TZ=Asia/Kolkata
# 1st day of month at 01:00
SCHEDULER_POTM_CRON=0 1 1 * *
# Sunday at 01:00
SCHEDULER_GLOBAL_LEADERBOARD_CRON=0 1 * * 0
# Comma separated game IDs from your system
SCHEDULER_POTM_GAME_IDS=BGMI
SCHEDULER_GLOBAL_LEADERBOARD_GAME_IDS=BGMI
# Extra traces for recurring integrity checks
SCHEDULER_DEBUG=true
